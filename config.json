{
  "manager": {
    "endpoint": "http://localhost:8000/v1/chat/completions",
    "model": "Intel/Qwen3.5-122B-A10B-int4-AutoRound",
    "timeout": 600,
    "temperature": 0.2,
    "plan_max_tokens": 8192,
    "audit_max_tokens": 2048,
    "execute_max_tokens": 8192
  },
  "intern": {
    "endpoint": "http://localhost:11434/api/chat",
    "model": "qwen3:8b",
    "timeout": 300,
    "temperature": 0.1,
    "max_tokens": 8192,
    "num_ctx": 24576
  },
  "searxng": {
    "endpoint": "http://localhost:8080/search",
    "timeout": 30,
    "max_results": 5,
    "page_chars": 4000,
    "max_queries_per_step": 4,
    "max_fetch_top": 3,
    "max_page_bytes": 262144
  },
  "skills": {
    "dirs": ["{workspace}/.claude/skills"],
    "max_skill_chars": 6000,
    "max_per_step": 2,
    "auto_propose": true,
    "propose_attempt_chars": 2500,
    "propose_max_tokens": 4096
  },
  "run": {
    "max_step_retries": 2,
    "max_transport_retries": 2,
    "check_timeout": 120,
    "context_char_budget": 24000,
    "audit_file_char_budget": 8000,
    "allowed_check_binaries": ["python3", "python", "pytest", "grep", "test", "ls", "diff", "cat", "bash", "node"]
  }
}
